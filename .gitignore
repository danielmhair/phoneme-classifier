# LOSO harness generated data: embedding cache and augmented audio (large,
# regenerable, machine-specific paths) and per-run results (reproducible by
# re-running evaluation/harness/loso_runner.py). Harness source code itself
# (evaluation/harness/*.py) is NOT covered by this and stays tracked.
evaluation/harness_cache/
evaluation/loso_results/
# Full-corpus models + recorded live-mic sessions (regenerable via
# `poe live-mic-train`; sessions are personal audio, like recordings/)
evaluation/full_models*/
evaluation/live_mic_sessions/

# The Phoneme Hatchery app lives in its own repo, colocated here for dev
# convenience (see game/README.md) - never part of this repo's history
light-haven-sites/

# Windows Zone.Identifier files
*.Zone.Identifier